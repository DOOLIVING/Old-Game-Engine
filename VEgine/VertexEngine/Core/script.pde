// Глобальная переменная для хранения изображения текстуры
// Загружается в GameLevel и используется для отрисовки куба
PImage img;

// ============================================================
// КЛАСС СЦЕНЫ МЕНЮ
// ============================================================
// Класс MenuScene наследуется от базового класса Scene (предположительно, часть вашего движка)
// Отвечает за отображение главного меню игры
class MenuScene extends Scene {
  
  // Флаг, предотвращающий повторный запуск фоновой музыки
  // Сейчас не используется, но оставлен для будущей реализации звука
  boolean musicStarted = false;

  // Конструктор класса MenuScene
  // Вызывается один раз при создании сцены меню
  MenuScene() {
    // Устанавливаем цвет фона сцены (светло-серый, 200 из 255)
    bgColor = 200;
    
    // ===== СОЗДАНИЕ КНОПКИ "ИГРАТЬ" =====
    // Добавляем кнопку в глобальный список worldButton (массив кнопок сцены)
    // Параметры кнопки: x, y, ширина, высота, цвет(R), цвет(G), цвет(B), радиус скругления, текст
    // Кнопка расположена по центру экрана: 
    // X = половина ширины окна минус половина ширины кнопки (75 пикселей)
    // Y = половина высоты окна
    worldButton.add(new button(width/2 - 75, height/2, 150, 40, 120, 10, 10, "ИГРАТЬ"));
    
    // ===== СОЗДАНИЕ ТЕКСТОВОГО ЗАГОЛОВКА =====
    // Добавляем текст в глобальный список worldTexts
    // Параметры: x, y, цвет(R), цвет(G), цвет(B), сам текст, размер шрифта
    // Заголовок "OLD GAME ENGINE" выводится в верхней части экрана
    worldTexts.add(new texts(120, 120, 120, 100, 100, "OLD GAME ENGINE", 320));
  }

  // ===== МЕТОД ОБНОВЛЕНИЯ СЦЕНЫ =====
  // @Override означает, что мы переопределяем метод родительского класса Scene
  // Этот метод вызывается каждый кадр (60 раз в секунду при стандартных настройках)
  @Override
  void update() {
    // Вызываем родительский метод update() для обработки базовой логики сцены
    // (например, отрисовки фона, обработки всех объектов в списках)
    super.update();
    
    // ===== ПРОВЕРКА НАЖАТИЯ НА КНОПКУ =====
    // Проверяем, что список кнопок не пуст
    // worldButton.get(0) - получаем первую (и единственную) кнопку в сцене
    // isClicked() - метод, проверяющий, был ли клик мышью по кнопке в этом кадре
    if (worldButton.size() > 0 && worldButton.get(0).isClicked()) {
      
      // Отладочное сообщение в консоль Processing
      println("Кнопка нажата, переход в GameLevel");
      
      // ===== ПЕРЕКЛЮЧЕНИЕ СЦЕНЫ =====
      // Создаем новый экземпляр игрового уровня
      // Глобальная переменная currentScene теперь указывает на GameLevel
      // Движок начнет отрисовывать и обновлять новую сцену со следующего кадра
      currentScene = new GameLevel();
    }
  }
}

// ============================================================
// ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ДЛЯ ИГРОВОГО УРОВНЯ
// ============================================================

// Xcar - глобальная переменная для хранения позиции машины по оси X
// Используется в функции movement() для управления моделью
float Xcar = 0;

// mainCar - глобальная ссылка на объект модели машины
// Вынесена за пределы класса GameLevel, чтобы функция movement() имела к ней доступ
// Это временное решение, лучше передавать модель через параметры
model mainCar;

// ============================================================
// КЛАСС ИГРОВОЙ СЦЕНЫ
// ============================================================
class GameLevel extends Scene {
  
  // Конструктор класса GameLevel
  // Выполняется при создании игрового уровня
  GameLevel() {
    // ===== ЗАГРУЗКА ТЕКСТУРЫ =====
    // Загружаем изображение "images.jpeg" из папки data скетча
    // Это изображение будет использовано как текстура для куба
    img = loadImage("images.jpeg");
    
    // Устанавливаем темно-серый цвет фона для игровой сцены
    bgColor = 50;
    
    setShader("data/ef.glsl");
    
    // ===== СОЗДАНИЕ КУБА С ТЕКСТУРОЙ =====
    // Добавляем куб в глобальный список worldCubes
    // Параметры: x, y, z, размер, R, G, B, использовать текстуру (true), текстура
    // Куб расположен в центре координат (0,0,0) с размером 50 единиц
    // Цвет установлен красный (255,0,0), но с текстурой будет видна картинка
    worldCubes.add(new cube(0, 0, 0, 50, 255, 0, 0, true, img));
    
    worldCubes.add(new cube(0, 120, 0, 50, 0, 200, 0, false));
    
    // ===== СОЗДАНИЕ СИСТЕМЫ ЧАСТИЦ =====
    // Добавляем систему частиц в центр координат для визуального эффекта
    // PVector(0,0,0) - начальная позиция источника частиц
    worldParticles.add(new ParticleSystem(new PVector(0, 0, 0)));
    
    // ===== СОЗДАНИЕ МОДЕЛИ МАШИНЫ =====
    // Создаем экземпляр класса model с параметрами:
    // Xcar - начальная позиция по X
    // 0, 0 - позиция по Y и Z
    // 50 - размер/масштаб модели
    // "data/car.obj" - путь к файлу 3D-модели в формате Wavefront OBJ
    mainCar = new model(0, 0, 0, 50, "data/car.obj");
    
    // Поворачиваем модель на 180 градусов вокруг оси X
    // radians(180) преобразует градусы в радианы (результат ≈ 3.14159)
    // Это нужно для правильной ориентации модели (возможно, модель загружена "вверх ногами")
    mainCar.rotX = radians(180); 
    
    // ===== ДОБАВЛЕНИЕ МАШИНЫ В СПИСОК МОДЕЛЕЙ СЦЕНЫ =====
    // ОБЯЗАТЕЛЬНОЕ действие! Без этого движок не будет отрисовывать модель
    // worldModels - глобальный список всех 3D-моделей на сцене
    worldModels.add(mainCar);
    
    // ===== НАСТРОЙКА УПРАВЛЕНИЯ МЫШЬЮ =====
    // Скрываем системный курсор мыши (в игре будет отрисовываться свой)
    mouse_state = true;
    
    // Устанавливаем тип курсора в виде перекрестия (прицел)
    type_cursor = "Cross";
    
    // ===== ОСТАНОВКА МУЗЫКИ ИЗ МЕНЮ =====
    // Проверяем, есть ли в списке звуков какие-либо треки
    // Останавливаем первый трек (музыку меню), чтобы она не играла в игре
    if (worldSound.size() > 0) {
      worldSound.get(0).stop();
    }
  }

  // ===== МЕТОД ОБНОВЛЕНИЯ ИГРОВОЙ СЦЕНЫ =====
  // Вызывается каждый кадр
  @Override
  void update() {
    // Вызов родительского метода для обработки базовой логики сцены
    // (отрисовка фона, обновление всех объектов в списках)
    super.update();
    
    // Вызов функции обработки пользовательского ввода
    // movement() отвечает за управление камерой и моделью машины
    movement();  
  }
}

// ============================================================
// ФУНКЦИЯ ОБРАБОТКИ УПРАВЛЕНИЯ
// ============================================================
// Глобальная функция (public - доступна отовсюду)
// Обрабатывает нажатия клавиш для управления камерой и объектами
public void movement() {
  // Проверяем, нажата ли в данный момент какая-либо клавиша на клавиатуре
  // keyPressed - встроенная переменная Processing
  if (keyPressed == true) {
    
    // Скорость вращения камеры (в радианах за кадр)
    // Маленькое значение (0.03) обеспечивает плавный поворот
    float rotateSpeed = 0.03;
    
    // ===== УПРАВЛЕНИЕ ПОЗИЦИЕЙ КАМЕРЫ (ПЕРЕМЕЩЕНИЕ) =====
    // Используются как латинские, так и русские раскладки клавиатуры
    
    // Движение камеры ВЛЕВО по оси X (клавиши A или Ф)
    if(key == 'a' || key == 'ф') sceneCamera.x -= 2.0;
    
    // Движение камеры ВПРАВО по оси X (клавиши D или В)
    if(key == 'd' || key == 'в') sceneCamera.x += 2.0;
    
    // Движение камеры ВПЕРЕД по оси Z (клавиши W или Ц)
    // В 3D-графике ось Z обычно направлена "в экран"
    // Уменьшение Z = движение вперед
    if(key == 'w' || key == 'ц') sceneCamera.z -= 2.0;
    
    // Движение камеры НАЗАД по оси Z (клавиши S или Ы)
    // Увеличение Z = движение назад
    if(key == 's' || key == 'ы') sceneCamera.z += 2.0;
    
    // Движение камеры ВНИЗ по оси Y (клавиши Q или Й)
    if(key == 'q' || key == 'й') sceneCamera.y -= 2.0;
    
    // Движение камеры ВВЕРХ по оси Y (клавиши E или У)
    if(key == 'e' || key == 'у') sceneCamera.y += 2.0;
    
    // ===== УПРАВЛЕНИЕ МОДЕЛЬЮ МАШИНЫ =====
    // Движение машины ВПРАВО по оси X (клавиша R или К)
    if(key == 'r' || key == 'к') {
      // Увеличиваем глобальную переменную позиции
      Xcar += 2.0;
      
      // Если модель машины существует (проверка на null для безопасности)
      if(mainCar != null) {
        // Применяем новую позицию к модели
        mainCar.x = Xcar;
      }
    }
    
    // ===== УПРАВЛЕНИЕ ПОВОРОТОМ КАМЕРЫ (ВРАЩЕНИЕ) =====
    // Используются стрелки клавиатуры (keyCode вместо key)
    
    // Поворот камеры ВЛЕВО (вокруг оси Y - рыскание / yaw)
    // Уменьшаем угол yaw для поворота против часовой стрелки
    if(keyCode == LEFT)  sceneCamera.yaw -= rotateSpeed;
    
    // Поворот камеры ВПРАВО (вокруг оси Y - рыскание / yaw)
    // Увеличиваем угол yaw для поворота по часовой стрелке
    if(keyCode == RIGHT) sceneCamera.yaw += rotateSpeed;
    
    // Поворот камеры ВВЕРХ (вокруг оси X - тангаж / pitch)
    // Уменьшаем угол pitch, чтобы смотреть вверх
    if(keyCode == UP)    sceneCamera.pitch -= rotateSpeed;
    
    // Поворот камеры ВНИЗ (вокруг оси X - тангаж / pitch)
    // Увеличиваем угол pitch, чтобы смотреть вниз
    if(keyCode == DOWN)  sceneCamera.pitch += rotateSpeed;
  }
}
